<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE devices PUBLIC "-//YARP//DTD yarprobotinterface 3.0//EN" "http://www.yarp.it/DTD/yarprobotinterfaceV3.0.dtd">

<device xmlns:xi="http://www.w3.org/2001/XInclude" name="left_arm-calibrator" type="parametricCalibratorEth">
	<xi:include href="../general.xml" />
	<group name="GENERAL">
		<param name="joints"> 3 </param>
		<param name="deviceName"> Left_Arm_Calibrator 					    </param>
	</group>
	<group name="HOME">
		<param name="positionHome"> 0 0 0  								    </param>
		<param name="velocityHome"> 20 20 20 							    </param>
	</group>
	<group name="CALIBRATION">
		<param name="calibrationType"> 5 5 							        </param>
		<param name="calibration1"> 1000.0 1000.0 1000.0		            </param>
		<param name="calibration2"> 0.0 0.0 0.0  					        </param>
		<param name="calibration3"> 0.0 0.0 0.0 					        </param>
		<param name="calibration4"> 0 0 0   								</param>
        <param name="calibration5"> 0 0 0  								    </param>
        <param name="calibrationZero"> 0.0 0.0 0.0					        </param>
        <!-- TODO: Tune these parameters -->
        <!-- calibrationDelta retrieved from 'Zeros' of previous version         -->
		<param name="calibrationDelta"> -20.0 84.0 -75.0 		            </param>
		<param name="startupPosition"> 0.0 0.0 0.0 				            </param>
		<param name="startupVelocity"> 10.0 10.0 10.0 			            </param>
		<param name="startupMaxPwm"> 1400.0 1400.0 1400.0	                </param> <!-- TODO: Tune these parameters -->
		<param name="startupPosThreshold"> 1.0 1.0 1.0			            </param>
	</group>

	<param name="CALIB_ORDER">(0) (1) (2)</param> 
	<action phase="startup" level="10" type="calibrate">
		<param name="target">left_arm-mc_wrapper</param>
	</action>
	<action phase="interrupt1" level="1" type="park">
		<param name="target">left_arm-mc_wrapper</param>
	</action>
	<action phase="interrupt3" level="1" type="abort" />
	</device>
