        <param name="speedPid">                 2FOC_VEL_CONTROL    2FOC_VEL_CONTROL    2FOC_VEL_CONTROL    </param>
    </group>


    <!-- default position PID: begin -->
    
    <!-- TODO: Review and tune these parameters -->
