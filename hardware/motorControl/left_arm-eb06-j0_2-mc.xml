    <!-- joint number                           0                   1                   2                        -->
    <!-- joint name                             Left Shldr Scapula  Left Shldr Flection Left Shldr Abduction     -->      
    <group name="LIMITS">
        <param name="jntPosMin">                -18                 -75                 0                   </param> <!-- Imported from previous version -->
