        <param name="jntVelMax">                1000                1000                1000                </param>
        <param name="motorOverloadCurrents">    3000                3000                3000                </param> <!-- Imported from previous version -->
        <param name="motorNominalCurrents">     800                 800                 800                 </param> <!-- Imported from head motors      -->
        <param name="motorPeakCurrents">        1000                1000                1000                </param> <!-- Imported from head motors      -->
    
        <param name="motorPwmLimit">            2000                2000                2000                </param> <!-- Imported from head motors      -->
    </group>
   
    <group name="TIMEOUTS"> <!-- Imported from previous version -->
        <param name="velocity">                 100                 100                 100                 </param>
